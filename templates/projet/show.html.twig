{% extends 'base.html.twig' %}

{% block title %}{{ projet.refClient }} - Détails{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h1 class="h4 mb-0">
                            <i class="bi bi-eye"></i>
                            Détails du Projet
                        </h1>
                            <div class="btn-group" role="group">
                            <a href="{{ path('app_projet_choose_configuration', {projet: projet.id}) }}" class="btn btn-success">
                                <i class="bi bi-gear"></i> Configurer
                            </a>
                            <a href="{{ path('app_projet_edit', {id: projet.id}) }}" class="btn btn-warning">
                                <i class="bi bi-pencil"></i> Modifier
                            </a>
                            <a href="{{ path('app_projet_index') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Retour
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h5 class="text-primary mb-3">Informations du Projet</h5>
                            
                            <div class="mb-3">
                                <strong>ID :</strong> 
                                <span class="badge bg-primary">#{{ projet.id }}</span>
                            </div>
                            
                            <div class="mb-3">
                                <strong>Référence Client :</strong><br>
                                <span class="h6">{{ projet.refClient }}</span>
                            </div>
                            
                            <div class="mb-3">
                                <strong>Lieu :</strong><br>
                                {% if projet.lieu %}
                                    <i class="bi bi-geo-alt-fill text-muted"></i>
                                    {{ projet.lieu }}
                                {% else %}
                                    <span class="text-muted">Non spécifié</span>
                                {% endif %}
                            </div>
                            
                            <div class="mb-3">
                                <strong>Date de création :</strong><br>
                                <i class="bi bi-calendar-event text-muted"></i>
                                {{ projet.createdAt|date('d/m/Y à H:i') }}
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <h5 class="text-info mb-3">Informations du Client</h5>
                            
                            {% if projet.client %}
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="avatar bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; font-size: 20px;">
                                                {{ projet.client.nom|first|upper }}
                                            </div>
                                            <div>
                                                <h6 class="mb-0">{{ projet.client.nom }}</h6>
                                                <small class="text-muted">Client</small>
                                            </div>
                                        </div>
                                        
                                        {% if projet.client.email %}
                                            <div class="mb-2">
                                                <i class="bi bi-envelope text-muted"></i>
                                                <a href="mailto:{{ projet.client.email }}">{{ projet.client.email }}</a>
                                            </div>
                                        {% endif %}
                                        
                                        {% if projet.client.tel %}
                                            <div class="mb-2">
                                                <i class="bi bi-telephone text-muted"></i>
                                                <a href="tel:{{ projet.client.tel }}">{{ projet.client.tel }}</a>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% else %}
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle"></i>
                                    Aucun client associé à ce projet
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    
                    {% if projet.description %}
                        <hr>
                        <div class="mb-3">
                            <h5 class="text-success mb-3">Description</h5>
                            <div class="card bg-light">
                                <div class="card-body">
                                    {{ projet.description|nl2br }}
                                </div>
                            </div>
                        </div>
                    {% endif %}
                    
                    <hr>
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <h5 class="text-primary mb-3">
                                <i class="bi bi-gear"></i>
                                État des Configurations
                            </h5>
                            
                            <!-- Configuration Portes/Fenêtres -->
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="card {{ projet.confPfId ? 'border-success' : 'border-warning' }}">
                                        <div class="card-body">
                                            <h6 class="card-title">
                                                <i class="bi bi-window"></i>
                                                Portes & Fenêtres
                                            </h6>
                                            {% if projet.confPfId and confPf %}
                                                <div class="alert alert-success p-2 mb-2">
                                                    <small><i class="bi bi-check-circle"></i> Configuré</small>
                                                </div>
                                                
                                                <!-- Détails de la configuration -->
                                                <div class="configuration-details">
                                                    {% if confPf.produit %}
                                                        <div class="mb-2">
                                                            <strong class="text-primary">Produit :</strong>
                                                            <span class="badge bg-primary">{{ confPf.produit.nom }}</span>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.categorie %}
                                                        <div class="mb-2">
                                                            <strong class="text-info">Catégorie :</strong>
                                                            <span class="badge bg-info">{{ confPf.categorie.nom }}</span>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.sousCategorie %}
                                                        <div class="mb-2">
                                                            <strong class="text-success">Sous-catégorie :</strong>
                                                            <span class="badge bg-success">{{ confPf.sousCategorie.nom }}</span>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.largeur or confPf.hauteur %}
                                                        <div class="mb-2">
                                                            <strong class="text-dark">Dimensions :</strong>
                                                            {% if confPf.largeur %}{{ confPf.largeur }}{% endif %}
                                                            {% if confPf.largeur and confPf.hauteur %} × {% endif %}
                                                            {% if confPf.hauteur %}{{ confPf.hauteur }}{% endif %}
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.quantite %}
                                                        <div class="mb-2">
                                                            <strong class="text-dark">Quantité :</strong>
                                                            <span class="badge bg-dark">{{ confPf.quantite }}</span>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.position %}
                                                        <div class="mb-2">
                                                            <strong class="text-dark">Position :</strong>
                                                            <span class="badge bg-secondary">{{ confPf.position }}</span>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.ouverture %}
                                                        <div class="mb-2">
                                                            <strong class="text-dark">Ouverture :</strong>
                                                            <span class="badge bg-info">{{ confPf.ouverture.nom }}</span>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.fournisseur %}
                                                        <div class="mb-2">
                                                            <strong class="text-dark">Fournisseur :</strong>
                                                            <span class="badge bg-warning text-dark">{{ confPf.fournisseur.marque }}</span>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.systeme %}
                                                        <div class="mb-2">
                                                            <strong class="text-dark">Système :</strong>
                                                            <span class="badge bg-info text-white">{{ confPf.systeme.nom }}</span>
                                                            {% if confPf.systeme.description %}
                                                                <div class="small text-muted mt-1">{{ confPf.systeme.description }}</div>
                                                            {% endif %}
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.notes %}
                                                        <div class="mb-2">
                                                            <strong class="text-muted">Notes :</strong>
                                                            <div class="small text-muted">{{ confPf.notes|slice(0, 100) }}{% if confPf.notes|length > 100 %}...{% endif %}</div>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    {% if confPf.createdAt %}
                                                        <div class="mb-2">
                                                            <small class="text-muted">
                                                                <i class="bi bi-clock"></i>
                                                                Configuré le {{ confPf.createdAt|date('d/m/Y à H:i') }}
                                                            </small>
                                                        </div>
                                                    {% endif %}
                                                </div>
                                                
                                                <div class="mt-3">
                                                    <a href="{{ path('app_configuration_pf_details', {projet: projet.id, confpf: confPf.id}) }}" 
                                                       class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-eye"></i> Voir détails
                                                    </a>
                                                    <a href="{{ path('app_configuration_pf', {projet: projet.id}) }}" 
                                                       class="btn btn-sm btn-outline-secondary">
                                                        <i class="bi bi-pencil"></i> Modifier
                                                    </a>
                                                </div>
                                            {% else %}
                                                <span class="badge bg-warning">
                                                    <i class="bi bi-exclamation-triangle"></i> Non configuré
                                                </span>
                                                <div class="mt-2">
                                                    <a href="{{ path('app_projet_configure_pf', {projet: projet.id}) }}" class="btn btn-sm btn-outline-primary">
                                                        Configurer maintenant
                                                    </a>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="card {{ projet.confVoletId ? 'border-success' : 'border-warning' }}">
                                        <div class="card-body">
                                            <h6 class="card-title">
                                                <i class="bi bi-house-door"></i>
                                                Volets Roulants
                                            </h6>
                                            {% if projet.confVoletId %}
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle"></i> Configuré (ID: {{ projet.confVoletId }})
                                                </span>
                                                <div class="mt-2">
                                                    <small class="text-muted">
                                                        <i class="bi bi-tools"></i>
                                                        Configuration des volets en cours de développement
                                                    </small>
                                                </div>
                                            {% else %}
                                                <span class="badge bg-warning">
                                                    <i class="bi bi-exclamation-triangle"></i> Non configuré
                                                </span>
                                                <div class="mt-2">
                                                    <a href="{{ path('app_projet_configure_volet', {projet: projet.id}) }}" class="btn btn-sm btn-outline-info">
                                                        Configurer maintenant
                                                    </a>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <hr>
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-muted">Configuration Porte/Fenêtre</h6>
                            {% if projet.confPfId %}
                                <span class="badge bg-info">ID: {{ projet.confPfId }}</span>
                            {% else %}
                                <span class="text-muted">Non configuré</span>
                            {% endif %}
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Configuration Volet</h6>
                            {% if projet.confVoletId %}
                                <span class="badge bg-info">ID: {{ projet.confVoletId }}</span>
                            {% else %}
                                <span class="text-muted">Non configuré</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.configuration-details {
    background-color: #f8f9fa;
    border-radius: 0.375rem;
    padding: 0.75rem;
    margin-top: 0.5rem;
}

.configuration-details .badge {
    font-size: 0.75rem;
    margin-left: 0.25rem;
}

.configuration-details > div {
    border-bottom: 1px solid #e9ecef;
    padding-bottom: 0.25rem;
}

.configuration-details > div:last-child {
    border-bottom: none;
    padding-bottom: 0;
}

.card.border-success .configuration-details {
    border-left: 4px solid #198754;
}

.card.border-warning .configuration-details {
    border-left: 4px solid #ffc107;
}
</style>
{% endblock %}