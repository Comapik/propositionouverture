<!-- Modal simple pour agrandir les photos -->
<div class="modal fade" id="photoModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Photo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalPhoto" src="" alt="" class="img-fluid rounded" style="max-height: 70vh;">
                <div class="mt-3">
                    <small class="text-muted d-block" id="modalFilename"></small>
                    <small class="text-muted d-block" id="modalDate"></small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

<script>
// Gestion de l'agrandissement des photos
document.addEventListener('DOMContentLoaded', function() {
    const photoModal = document.getElementById('photoModal');
    const modalImg = document.getElementById('modalPhoto');
    const modalTitle = document.getElementById('modalTitle');
    const modalFilename = document.getElementById('modalFilename');
    const modalDate = document.getElementById('modalDate');

    document.querySelectorAll('.project-photo').forEach(img => {
        img.addEventListener('click', function() {
            modalImg.src = this.dataset.photoSrc;
            modalTitle.textContent = this.dataset.photoTitle;
            modalFilename.textContent = 'Fichier: ' + this.dataset.photoFilename;
            modalDate.textContent = this.dataset.photoDate ? 'Ajouté le: ' + this.dataset.photoDate : '';
            
            const modal = new bootstrap.Modal(photoModal);
            modal.show();
        });
    });
});
</script>
