<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Symfony App{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
            <style>
                /* Styles pour les messages flash regroupés */
                #flash-messages-container {
                    transition: all 0.3s ease-in-out;
                    animation: slideInDown 0.3s ease-out;
                }
                
                @keyframes slideInDown {
                    from {
                        opacity: 0;
                        transform: translateY(-20px);
                    }
                    to {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }
                
                .flash-message-item {
                    transition: all 0.2s ease-in-out;
                    border: 1px solid rgba(0,0,0,0.1);
                    animation: fadeInUp 0.3s ease-out;
                }
                
                @keyframes fadeInUp {
                    from {
                        opacity: 0;
                        transform: translateY(10px);
                    }
                    to {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }
                
                .flash-message-item:hover {
                    transform: translateX(5px);
                    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
                }
                
                .flash-message-item button {
                    opacity: 0.6;
                    transition: opacity 0.2s ease;
                }
                
                .flash-message-item:hover button {
                    opacity: 1;
                }
                
                .alert-heading {
                    color: #495057;
                    font-weight: 600;
                }
                
                /* Style pour la croix principale */
                .btn-close {
                    opacity: 0.7;
                    transition: all 0.2s ease;
                    background-size: 1.2em;
                }
                
                .btn-close:hover {
                    opacity: 1;
                    transform: scale(1.1);
                }
                
                /* Animation de sortie pour les messages */
                .flash-message-removing {
                    opacity: 0 !important;
                    transform: scale(0.95) !important;
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                // Gestion des messages flash regroupés
                function removeFlashMessage(button) {
                    const messageItem = button.closest('.flash-message-item');
                    messageItem.style.opacity = '0.5';
                    messageItem.style.transform = 'scale(0.95)';
                    
                    setTimeout(() => {
                        messageItem.remove();
                        updateFlashCount();
                    }, 200);
                }
                
                function closeAllFlashMessages() {
                    const container = document.getElementById('flash-messages-container');
                    if (container) {
                        container.style.opacity = '0';
                        container.style.transform = 'translateY(-20px)';
                        
                        setTimeout(() => {
                            container.remove();
                        }, 300);
                    }
                }
                
                function updateFlashCount() {
                    const messagesList = document.getElementById('flash-messages-list');
                    const remainingMessages = messagesList.querySelectorAll('.flash-message-item').length;
                    
                    if (remainingMessages === 0) {
                        closeAllFlashMessages();
                    } else {
                        const heading = document.querySelector('.alert-heading');
                        if (heading) {
                            heading.innerHTML = '<i class="bi bi-info-circle me-1"></i>Notifications (' + remainingMessages + ')';
                        }
                    }
                }
                
                // Auto-hide après 10 secondes pour les messages de succès
                document.addEventListener('DOMContentLoaded', function() {
                    const successMessages = document.querySelectorAll('.flash-message-item');
                    successMessages.forEach(function(message) {
                        const isSuccess = message.style.backgroundColor.includes('d1e7dd');
                        if (isSuccess) {
                            setTimeout(() => {
                                if (message.parentNode) {
                                    removeFlashMessage(message.querySelector('button'));
                                }
                            }, 10000); // 10 secondes
                        }
                    });
                });
            </script>
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    <strong>Proposition Ouverture</strong>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">
                                <i class="bi bi-house"></i> Accueil
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_projet_index') }}">
                                <i class="bi bi-folder2-open"></i> Projets
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_client_index') }}">
                                <i class="bi bi-people"></i> Clients
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-plus-circle"></i> Nouveau
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_projet_new') }}">
                                    <i class="bi bi-folder-plus"></i> Nouveau Projet
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('app_client_new') }}">
                                    <i class="bi bi-person-plus"></i> Nouveau Client
                                </a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Messages Flash regroupés -->
        {% set flash_messages = [] %}
        {% for label in ['success', 'error', 'warning', 'info', 'danger'] %}
            {% for message in app.flashes(label) %}
                {% set flash_messages = flash_messages|merge([{type: label, message: message}]) %}
            {% endfor %}
        {% endfor %}
        
        {% if flash_messages|length > 0 %}
            <div id="flash-messages-container" class="container mt-3">
                <div class="alert alert-dismissible fade show" role="alert" 
                     style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border: 1px solid #dee2e6; border-radius: 8px;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="alert-heading mb-2">
                                <i class="bi bi-info-circle me-1"></i>
                                Notifications ({{ flash_messages|length }})
                            </h6>
                            <div id="flash-messages-list">
                                {% for flash in flash_messages %}
                                    <div class="flash-message-item d-flex align-items-center mb-2 p-2 rounded" 
                                         style="background-color: {% if flash.type == 'success' %}#d1e7dd{% elseif flash.type == 'error' or flash.type == 'danger' %}#f8d7da{% elseif flash.type == 'warning' %}#fff3cd{% else %}#cff4fc{% endif %};">
                                        <i class="bi {% if flash.type == 'success' %}bi-check-circle text-success{% elseif flash.type == 'error' or flash.type == 'danger' %}bi-exclamation-circle text-danger{% elseif flash.type == 'warning' %}bi-exclamation-triangle text-warning{% else %}bi-info-circle text-info{% endif %} me-2"></i>
                                        <span class="flex-grow-1">{{ flash.message }}</span>
                                        <button type="button" class="btn btn-sm btn-outline-secondary ms-2" onclick="removeFlashMessage(this)" title="Supprimer ce message">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                        <button type="button" class="btn-close ms-3" onclick="closeAllFlashMessages()" 
                                aria-label="Fermer toutes les notifications" title="Fermer toutes les notifications"></button>
                    </div>
                </div>
            </div>
        {% endif %}
        
        <main role="main">
            {% block body %}{% endblock %}
        </main>
        
        <footer class="bg-light mt-5 py-4">
            <div class="container text-center">
                <p class="text-muted">&copy; {{ 'now'|date('Y') }} Symfony App - Construit avec les principes SOLID, DRY et KISS</p>
            </div>
        </footer>
    </body>
</html>
