{% extends 'base.html.twig' %}

{% block title %}{{ client.nom }} - Détails du client{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- En-tête -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">
                    <i class="bi bi-person-fill text-primary me-2"></i>
                    Détails du client
                </h1>
                <div class="btn-group">
                    <a href="{{ path('app_client_edit', {'id': client.id}) }}" class="btn btn-primary">
                        <i class="bi bi-pencil me-2"></i>
                        Modifier
                    </a>
                    <a href="{{ path('app_client_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>
                        Retour à la liste
                    </a>
                </div>
            </div>

            <!-- Informations du client -->
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <div class="d-flex align-items-center">
                            <div class="avatar-lg bg-white text-primary rounded-circle d-flex align-items-center justify-content-center me-3">
                                {{ client.nom|slice(0,1)|upper }}
                            </div>
                            <div>
                                <h4 class="mb-0">{{ client.nom }}</h4>
                                <small class="opacity-75">Client</small>
                            </div>
                        </div>
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">
                                <i class="bi bi-person me-2"></i>
                                Nom complet
                            </h6>
                            <p class="h5 mb-4">{{ client.nom }}</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">
                                <i class="bi bi-envelope me-2"></i>
                                Adresse email
                            </h6>
                            <p class="h6 mb-4">
                                {% if client.email %}
                                    <a href="mailto:{{ client.email }}" class="text-decoration-none">
                                        {{ client.email }}
                                    </a>
                                {% else %}
                                    <span class="text-muted">Non renseigné</span>
                                {% endif %}
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">
                                <i class="bi bi-telephone me-2"></i>
                                Numéro de téléphone
                            </h6>
                            <p class="h6 mb-4">
                                {% if client.tel %}
                                    <a href="tel:{{ client.tel }}" class="text-decoration-none">
                                        {{ client.tel }}
                                    </a>
                                {% else %}
                                    <span class="text-muted">Non renseigné</span>
                                {% endif %}
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">
                                <i class="bi bi-calendar-check me-2"></i>
                                Date de création
                            </h6>
                            <p class="h6 mb-4">
                                {% if client.createdAt %}
                                    {{ client.createdAt|date('d/m/Y à H:i') }}
                                {% else %}
                                    <span class="text-muted">Non disponible</span>
                                {% endif %}
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Projets associés -->
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-briefcase me-2"></i>
                        Projets associés
                        <span class="badge bg-primary ms-2">{{ client.projets|length }}</span>
                    </h5>
                </div>
                <div class="card-body">
                    {% if client.projets|length > 0 %}
                        <div class="row">
                            {% for projet in client.projets %}
                                <div class="col-md-6 mb-3">
                                    <div class="card border">
                                        <div class="card-body">
                                            <h6 class="card-title">
                                                <i class="bi bi-folder me-2"></i>
                                                {{ projet.refClient }}
                                            </h6>
                                            {% if projet.description %}
                                                <p class="card-text text-muted small">
                                                    {{ projet.description|slice(0, 100) }}
                                                    {% if projet.description|length > 100 %}...{% endif %}
                                                </p>
                                            {% endif %}
                                            {% if projet.lieu %}
                                                <p class="card-text">
                                                    <small class="text-muted">
                                                        <i class="bi bi-geo-alt me-1"></i>
                                                        {{ projet.lieu }}
                                                    </small>
                                                </p>
                                            {% endif %}
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    {% if projet.confPfId %}
                                                        <span class="badge bg-success me-1">P/F</span>
                                                    {% endif %}
                                                    {% if projet.confVoletId %}
                                                        <span class="badge bg-info">Volets</span>
                                                    {% endif %}
                                                    {% if not projet.confPfId and not projet.confVoletId %}
                                                        <span class="badge bg-warning">À configurer</span>
                                                    {% endif %}
                                                </div>
                                                <a href="{{ path('app_projet_show', {'id': projet.id}) }}" 
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="bi bi-folder-x display-4 text-muted mb-3"></i>
                            <h6 class="text-muted">Aucun projet associé</h6>
                            <p class="text-muted">Ce client n'a pas encore de projet.</p>
                            <a href="{{ path('app_projet_new') }}" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-2"></i>
                                Créer un projet pour ce client
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-between mt-4">
                <div>
                    <a href="{{ path('app_client_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>
                        Retour à la liste
                    </a>
                </div>
                <div>
                    <a href="{{ path('app_client_edit', {'id': client.id}) }}" class="btn btn-primary me-2">
                        <i class="bi bi-pencil me-2"></i>
                        Modifier
                    </a>
                    {% if client.projets|length == 0 %}
                        <form method="post" 
                              action="{{ path('app_client_delete', {'id': client.id}) }}" 
                              style="display: inline;"
                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce client ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-trash me-2"></i>
                                Supprimer
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.avatar-lg {
    width: 4rem;
    height: 4rem;
    font-size: 1.5rem;
    font-weight: 700;
}

.card {
    transition: all 0.3s ease;
}

.card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
}
</style>
{% endblock %}