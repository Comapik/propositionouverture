{% extends 'base.html.twig' %}

{% block title %}Liste des clients{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">
                    <i class="bi bi-people-fill text-primary me-2"></i>
                    Liste des clients
                </h1>
                <a href="{{ path('app_client_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>
                    Nouveau client
                </a>
            </div>

            {% if clients is empty %}
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle me-2"></i>
                    Aucun client enregistré pour le moment.
                    <br>
                    <a href="{{ path('app_client_new') }}" class="btn btn-primary mt-3">
                        <i class="bi bi-plus-circle me-2"></i>
                        Créer le premier client
                    </a>
                </div>
            {% else %}
                <div class="card shadow">
                    <div class="card-header bg-light">
                        <div class="row align-items-center">
                            <div class="col">
                                <h5 class="mb-0">
                                    <i class="bi bi-list-ul me-2"></i>
                                    {{ clients|length }} client{{ clients|length > 1 ? 's' : '' }} trouvé{{ clients|length > 1 ? 's' : '' }}
                                </h5>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">
                                            <i class="bi bi-person me-1"></i>
                                            Nom
                                        </th>
                                        <th scope="col">
                                            <i class="bi bi-envelope me-1"></i>
                                            Email
                                        </th>
                                        <th scope="col">
                                            <i class="bi bi-telephone me-1"></i>
                                            Téléphone
                                        </th>
                                        <th scope="col">
                                            <i class="bi bi-briefcase me-1"></i>
                                            Projets
                                        </th>
                                        <th scope="col" width="200">
                                            <i class="bi bi-gear me-1"></i>
                                            Actions
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for client in clients %}
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2">
                                                        {{ client.nom|slice(0,1)|upper }}
                                                    </div>
                                                    <strong>{{ client.nom }}</strong>
                                                </div>
                                            </td>
                                            <td>
                                                {% if client.email %}
                                                    <a href="mailto:{{ client.email }}" class="text-decoration-none">
                                                        {{ client.email }}
                                                    </a>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if client.tel %}
                                                    <a href="tel:{{ client.tel }}" class="text-decoration-none">
                                                        {{ client.tel }}
                                                    </a>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if client.projets|length > 0 %}
                                                    <span class="badge bg-success">
                                                        {{ client.projets|length }} projet{{ client.projets|length > 1 ? 's' : '' }}
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Aucun projet</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="{{ path('app_client_show', {'id': client.id}) }}" 
                                                       class="btn btn-sm btn-outline-primary" 
                                                       title="Voir">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <a href="{{ path('app_client_edit', {'id': client.id}) }}" 
                                                       class="btn btn-sm btn-outline-secondary" 
                                                       title="Modifier">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    {% if client.projets|length == 0 %}
                                                        <form method="post" 
                                                              action="{{ path('app_client_delete', {'id': client.id}) }}" 
                                                              style="display: inline;"
                                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce client ?')">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
                                                            <button type="submit" 
                                                                    class="btn btn-sm btn-outline-danger" 
                                                                    title="Supprimer">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </form>
                                                    {% else %}
                                                        <button type="button" 
                                                                class="btn btn-sm btn-outline-danger disabled" 
                                                                title="Impossible de supprimer : client avec projets"
                                                                disabled>
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    {% endif %}
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}

            <!-- Navigation -->
            <div class="d-flex justify-content-between mt-4">
                <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-house me-2"></i>
                    Accueil
                </a>
                <a href="{{ path('app_projet_index') }}" class="btn btn-outline-primary">
                    <i class="bi bi-briefcase me-2"></i>
                    Voir les projets
                </a>
            </div>
        </div>
    </div>
</div>

<style>
.avatar-sm {
    width: 2rem;
    height: 2rem;
    font-size: 0.875rem;
    font-weight: 600;
}

.table-hover tbody tr:hover {
    background-color: rgba(0, 123, 255, 0.05);
}

.btn-group .btn {
    border-radius: 0;
}

.btn-group .btn:first-child {
    border-top-left-radius: 0.375rem;
    border-bottom-left-radius: 0.375rem;
}

.btn-group .btn:last-child {
    border-top-right-radius: 0.375rem;
    border-bottom-right-radius: 0.375rem;
}
</style>
{% endblock %}