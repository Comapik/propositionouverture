{% extends 'base.html.twig' %}

{% block title %}Configuration {{ configuration_type }} - Sélection du produit{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-gear-fill me-2"></i>
                        Configuration {{ configuration_type }}
                    </h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h5 class="text-muted">Projet : {{ projet.refClient }}</h5>
                        <p class="text-muted">{{ projet.description }}</p>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Première étape : sélectionnez le type de produit que vous souhaitez configurer.
                    </div>

                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
                        
                        <div class="mb-4">
                            {{ form_widget(form.produit) }}
                            {{ form_errors(form.produit) }}
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_projet_choose_configuration', {'projet': projet.id}) }}" 
                               class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>
                                Retour
                            </a>
                            
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-arrow-right me-2"></i>
                                Continuer la configuration
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Form validation
    const form = document.querySelector('.needs-validation');
    const submitButton = form.querySelector('button[type="submit"]');
    const produitSelect = form.querySelector('select[name="product_selection[produit]"]');
    
    function toggleSubmitButton() {
        if (produitSelect.value) {
            submitButton.disabled = false;
            submitButton.classList.remove('btn-secondary');
            submitButton.classList.add('btn-primary');
        } else {
            submitButton.disabled = true;
            submitButton.classList.remove('btn-primary');
            submitButton.classList.add('btn-secondary');
        }
    }
    
    // Initial state
    toggleSubmitButton();
    
    // Listen for changes
    produitSelect.addEventListener('change', toggleSubmitButton);
    
    form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    });
});
</script>
{% endblock %}