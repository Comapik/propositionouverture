{% extends 'base.html.twig' %}

{% block title %}Configuration Portes/Fenêtres - Sélection de la sous-catégorie{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-folder2-open me-2"></i>
                        Sélection de la sous-catégorie
                    </h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h5 class="text-muted">Projet : {{ projet.refClient }}</h5>
                        <p class="text-muted">{{ projet.description }}</p>
                    </div>

                    <div class="alert alert-success">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            <div>
                                <strong>Produit :</strong> {{ produit.nom }}<br>
                                <strong>Catégorie :</strong> {{ categorie.nom }}
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Étape 3/3 : Choisissez maintenant la sous-catégorie pour affiner votre sélection.
                    </div>

                    {% if sousCategories|length > 0 %}
                        <form method="post">
                            <div class="row g-3">
                                {% for sousCategorie in sousCategories %}
                                    <div class="col-md-6">
                                        <div class="card border subcategory-card" style="cursor: pointer;">
                                            <div class="card-body text-center p-4">
                                                <div class="mb-3">
                                                    <i class="bi bi-folder-fill text-info" style="font-size: 2.5rem;"></i>
                                                </div>
                                                <h6 class="card-title">{{ sousCategorie.nom }}</h6>
                                                <small class="text-muted">{{ categorie.nom }}</small>
                                                <input type="radio" name="sous_categorie_id" value="{{ sousCategorie.id }}" class="d-none subcategory-radio">
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="d-flex justify-content-between mt-4">
                                <a href="{{ path('app_configuration_pf_category', {'projet': projet.id, 'confpf': confpf.id}) }}" 
                                   class="btn btn-secondary">
                                    <i class="bi bi-arrow-left me-2"></i>
                                    Changer de catégorie
                                </a>
                                
                                <button type="submit" class="btn btn-success btn-lg" id="submit-btn" disabled>
                                    <i class="bi bi-check-circle me-2"></i>
                                    Finaliser la sélection
                                </button>
                            </div>
                        </form>
                    {% else %}
                        <div class="alert alert-warning text-center">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Aucune sous-catégorie disponible pour cette catégorie.
                            <br>
                            <div class="mt-3">
                                <a href="{{ path('app_configuration_pf_category', {'projet': projet.id, 'confpf': confpf.id}) }}" 
                                   class="btn btn-secondary me-2">
                                    <i class="bi bi-arrow-left me-2"></i>
                                    Choisir une autre catégorie
                                </a>
                                <a href="{{ path('app_configuration_pf_details', {'projet': projet.id, 'confpf': confpf.id}) }}" 
                                   class="btn btn-primary">
                                    <i class="bi bi-arrow-right me-2"></i>
                                    Continuer sans sous-catégorie
                                </a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Progress indicator -->
            <div class="card mt-3 border-0">
                <div class="card-body py-2">
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <small class="text-success fw-bold">✓ Produit</small>
                        <small class="text-success fw-bold">✓ Catégorie</small>
                        <small class="text-primary fw-bold">→ Sous-catégorie</small>
                        <small class="text-muted">Configuration</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.subcategory-card {
    transition: all 0.3s ease;
    cursor: pointer;
}

.subcategory-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    border-color: #198754 !important;
}

.subcategory-card.selected {
    border-color: #198754 !important;
    background-color: rgba(25, 135, 84, 0.1);
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(25, 135, 84, 0.3);
}

.subcategory-card.selected .card-title {
    color: #198754;
    font-weight: bold;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const subcategoryCards = document.querySelectorAll('.subcategory-card');
    const submitBtn = document.getElementById('submit-btn');
    const radioInputs = document.querySelectorAll('.subcategory-radio');
    
    subcategoryCards.forEach((card, index) => {
        card.addEventListener('click', function() {
            // Remove selected class from all cards
            subcategoryCards.forEach(c => c.classList.remove('selected'));
            
            // Add selected class to clicked card
            card.classList.add('selected');
            
            // Check the corresponding radio button
            radioInputs[index].checked = true;
            
            // Enable submit button
            submitBtn.disabled = false;
            submitBtn.classList.remove('btn-secondary');
            submitBtn.classList.add('btn-success');
        });
    });
    
    // Form validation
    const form = document.querySelector('form');
    if (form) {
        form.addEventListener('submit', function(event) {
            const selectedRadio = document.querySelector('.subcategory-radio:checked');
            if (!selectedRadio) {
                event.preventDefault();
                alert('Veuillez sélectionner une sous-catégorie.');
            }
        });
    }
});
</script>
{% endblock %}