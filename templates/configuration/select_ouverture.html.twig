{% extends 'base.html.twig' %}

{% block title %}Sélection de l'ouverture - {{ parent() }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-door-open me-2"></i>
                        Sélection de l'ouverture
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Breadcrumb de progression -->
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a href="{{ path('app_projet_show', {id: projet.id}) }}">{{ projet.refClient }}</a>
                            </li>
                            <li class="breadcrumb-item">
                                <span class="badge bg-success">{{ produit.nom }}</span>
                            </li>
                            <li class="breadcrumb-item">
                                <span class="badge bg-success">{{ categorie.nom }}</span>
                            </li>
                            <li class="breadcrumb-item">
                                <span class="badge bg-success">{{ sousCategorie.nom }}</span>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">
                                <i class="bi bi-door-open me-1"></i>Ouverture
                            </li>
                        </ol>
                    </nav>

                    <!-- Résumé de la sélection -->
                    <div class="alert alert-info mb-4">
                        <strong>Configuration actuelle :</strong><br>
                        <i class="bi bi-box me-1"></i> <strong>Produit :</strong> {{ produit.nom }}<br>
                        <i class="bi bi-tag me-1"></i> <strong>Catégorie :</strong> {{ categorie.nom }}<br>
                        <i class="bi bi-tags me-1"></i> <strong>Sous-catégorie :</strong> {{ sousCategorie.nom }}
                    </div>

                    {% if ouvertures is empty %}
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Aucun type d'ouverture disponible pour cette sous-catégorie.
                        </div>
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_configuration_pf_subcategory', {projet: projet.id, confpf: confpf.id}) }}" 
                               class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Retour aux sous-catégories
                            </a>
                            <a href="{{ path('app_configuration_pf_details', {projet: projet.id, confpf: confpf.id}) }}" 
                               class="btn btn-primary">
                                Continuer sans ouverture <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    {% else %}
                        <p class="mb-4">
                            <i class="bi bi-info-circle me-2"></i>
                            Choisissez le type d'ouverture pour <strong>{{ sousCategorie.nom }}</strong> :
                        </p>

                        <form method="post">
                            <div class="row g-3">
                                {% for ouverture in ouvertures %}
                                    <div class="col-lg-4 col-md-6">
                                        <div class="card border ouverture-card" data-ouverture-id="{{ ouverture.id }}">
                                            <div class="position-relative ouverture-image-container">
                                                {% if ouverture.urlImage %}
                                                    <img src="{{ ouverture.urlImage }}" 
                                                         alt="{{ ouverture.nom }}" 
                                                         class="card-img-top ouverture-image">
                                                {% else %}
                                                    <div class="ouverture-placeholder d-flex align-items-center justify-content-center">
                                                        <i class="bi bi-door-open text-primary" style="font-size: 3.5rem;"></i>
                                                    </div>
                                                {% endif %}
                                                <div class="overlay">
                                                    <div class="overlay-content">
                                                        <i class="bi bi-check-circle-fill"></i>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="card-body text-center p-3">
                                                <h6 class="card-title mb-2">{{ ouverture.nom }}</h6>
                                                <small class="text-muted d-block">
                                                    <i class="bi bi-door-open me-1"></i>
                                                    Type d'ouverture
                                                </small>
                                                <input type="radio" 
                                                       name="ouverture_id" 
                                                       value="{{ ouverture.id }}" 
                                                       id="ouverture_{{ ouverture.id }}" 
                                                       class="d-none ouverture-radio">
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="row mt-4">
                                <div class="col-12">
                                    <div class="d-flex justify-content-between">
                                        <a href="{{ path('app_configuration_pf_subcategory', {projet: projet.id, confpf: confpf.id}) }}" 
                                           class="btn btn-outline-secondary">
                                            <i class="bi bi-arrow-left me-1"></i>Retour aux sous-catégories
                                        </a>
                                        
                                        <div>
                                            <a href="{{ path('app_configuration_pf_details', {projet: projet.id, confpf: confpf.id}) }}" 
                                               class="btn btn-outline-primary me-2">
                                                Passer cette étape
                                            </a>
                                            <button type="submit" class="btn btn-primary" id="submit-btn" disabled>
                                                Continuer <i class="bi bi-arrow-right ms-1"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.ouverture-card {
    transition: all 0.3s ease;
    cursor: pointer;
    overflow: hidden;
    border-radius: 12px;
    height: 100%;
}

.ouverture-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.15);
    border-color: #0d6efd !important;
}

.ouverture-card.selected {
    border-color: #0d6efd !important;
    border-width: 3px;
    transform: translateY(-8px);
    box-shadow: 0 12px 30px rgba(13, 110, 253, 0.4);
}

.ouverture-image-container {
    position: relative;
    min-height: 180px;
    height: auto;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
}

.ouverture-image {
    max-width: 100%;
    max-height: 160px;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: transform 0.3s ease;
}

.ouverture-placeholder {
    width: 100%;
    min-height: 160px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-bottom: 1px solid rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
}

.ouverture-card:hover .ouverture-image {
    transform: scale(1.05);
}

.overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(13, 110, 253, 0.9);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.ouverture-card.selected .overlay {
    opacity: 1;
}

.overlay-content i {
    color: white;
    font-size: 3rem;
    animation: checkmark 0.3s ease-in-out;
}

@keyframes checkmark {
    0% {
        transform: scale(0);
        opacity: 0;
    }
    50% {
        transform: scale(1.2);
    }
    100% {
        transform: scale(1);
        opacity: 1;
    }
}

.ouverture-card .card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
}

.ouverture-card.selected .card-title {
    color: #0d6efd;
}

.ouverture-card .card-body {
    background: white;
    position: relative;
}

.ouverture-card.selected .card-body {
    background: rgba(13, 110, 253, 0.05);
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .ouverture-image-container {
        min-height: 140px;
        padding: 8px;
    }
    
    .ouverture-image {
        max-height: 120px;
    }
    
    .ouverture-placeholder {
        min-height: 120px;
    }
}

@media (max-width: 576px) {
    .ouverture-image-container {
        min-height: 120px;
        padding: 6px;
    }
    
    .ouverture-image {
        max-height: 100px;
    }
    
    .ouverture-placeholder {
        min-height: 100px;
    }
    
    .overlay-content i {
        font-size: 2rem;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const ouvertureCards = document.querySelectorAll('.ouverture-card');
    const submitBtn = document.getElementById('submit-btn');
    const radioInputs = document.querySelectorAll('.ouverture-radio');
    
    // Désactiver le bouton submit au chargement
    submitBtn.disabled = true;
    
    ouvertureCards.forEach((card, index) => {
        card.addEventListener('click', function() {
            const ouvertureId = card.getAttribute('data-ouverture-id');
            const ouvertureNom = card.querySelector('.card-title').textContent.trim();
            
            // Remove selected class from all cards
            ouvertureCards.forEach(c => c.classList.remove('selected'));
            
            // Add selected class to clicked card
            card.classList.add('selected');
            
            // Check the corresponding radio button
            const radioInput = card.querySelector('.ouverture-radio');
            if (radioInput) {
                radioInput.checked = true;
            }
            
            // Enable submit button with animation
            if (submitBtn.disabled) {
                submitBtn.disabled = false;
                submitBtn.classList.remove('btn-secondary');
                submitBtn.classList.add('btn-primary');
                submitBtn.style.animation = 'pulse 0.3s ease-in-out';
            }
            
            // Update button text with selected opening name
            submitBtn.innerHTML = 'Continuer avec ' + ouvertureNom + ' <i class="bi bi-arrow-right ms-1"></i>';
            
            // Add a subtle feedback effect
            card.style.animation = 'selectPulse 0.3s ease-in-out';
            setTimeout(() => {
                card.style.animation = '';
                if (submitBtn.style.animation) {
                    submitBtn.style.animation = '';
                }
            }, 300);
        });
        
        // Add hover effects for better UX
        card.addEventListener('mouseenter', function() {
            if (!card.classList.contains('selected')) {
                card.style.borderColor = '#0d6efd';
            }
        });
        
        card.addEventListener('mouseleave', function() {
            if (!card.classList.contains('selected')) {
                card.style.borderColor = '';
            }
        });
    });
    
    // Form validation with user feedback
    const form = document.querySelector('form');
    if (form) {
        form.addEventListener('submit', function(event) {
            const selectedRadio = document.querySelector('.ouverture-radio:checked');
            if (!selectedRadio) {
                event.preventDefault();
                
                // Visual feedback for missing selection
                ouvertureCards.forEach(card => {
                    card.style.animation = 'shake 0.5s ease-in-out';
                    card.style.borderColor = '#dc3545';
                });
                
                // Show alert with better styling
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-warning alert-dismissible fade show mt-3';
                alertDiv.innerHTML = `
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Veuillez sélectionner un type d'ouverture avant de continuer.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                
                form.insertAdjacentElement('afterend', alertDiv);
                
                // Reset card animations after shake
                setTimeout(() => {
                    ouvertureCards.forEach(card => {
                        card.style.animation = '';
                        card.style.borderColor = '';
                    });
                }, 500);
                
                // Auto-remove alert after 5 seconds
                setTimeout(() => {
                    if (alertDiv && alertDiv.parentNode) {
                        alertDiv.remove();
                    }
                }, 5000);
                
                return false;
            }
        });
    }
});

// Add CSS animations for better UX
const style = document.createElement('style');
style.textContent = `
    @keyframes selectPulse {
        0% { transform: translateY(-8px) scale(1); }
        50% { transform: translateY(-8px) scale(1.05); }
        100% { transform: translateY(-8px) scale(1); }
    }
    
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }
    
    @keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }
`;
document.head.appendChild(style);
</script>
{% endblock %}