{% extends 'base.html.twig' %}

{% block title %}Sélection de l'ouverture - {{ parent() }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-door-open me-2"></i>
                        Sélection de l'ouverture
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Breadcrumb de progression -->
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a href="{{ path('app_projet_show', {id: projet.id}) }}">{{ projet.refClient }}</a>
                            </li>
                            <li class="breadcrumb-item">
                                <span class="badge bg-success">{{ produit.nom }}</span>
                            </li>
                            <li class="breadcrumb-item">
                                <span class="badge bg-success">{{ categorie.nom }}</span>
                            </li>
                            <li class="breadcrumb-item">
                                <span class="badge bg-success">{{ sousCategorie.nom }}</span>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">
                                <i class="bi bi-door-open me-1"></i>Ouverture
                            </li>
                        </ol>
                    </nav>

                    <!-- Résumé de la sélection -->
                    <div class="alert alert-info mb-4">
                        <strong>Configuration actuelle :</strong><br>
                        <i class="bi bi-box me-1"></i> <strong>Produit :</strong> {{ produit.nom }}<br>
                        <i class="bi bi-tag me-1"></i> <strong>Catégorie :</strong> {{ categorie.nom }}<br>
                        <i class="bi bi-tags me-1"></i> <strong>Sous-catégorie :</strong> {{ sousCategorie.nom }}
                    </div>

                    {% if ouvertures is empty %}
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Aucun type d'ouverture disponible pour cette sous-catégorie.
                        </div>
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_configuration_pf_subcategory', {projet: projet.id, confpf: confpf.id}) }}" 
                               class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Retour aux sous-catégories
                            </a>
                            <a href="{{ path('app_configuration_pf_details', {projet: projet.id, confpf: confpf.id}) }}" 
                               class="btn btn-primary">
                                Continuer sans ouverture <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    {% else %}
                        <p class="mb-4">
                            <i class="bi bi-info-circle me-2"></i>
                            Choisissez le type d'ouverture pour <strong>{{ sousCategorie.nom }}</strong> :
                        </p>

                        <form method="post">
                            <div class="row">
                                {% for ouverture in ouvertures %}
                                    <div class="col-md-6 mb-3">
                                        <div class="card h-100 ouverture-card" style="cursor: pointer;" 
                                             onclick="selectOuverture({{ ouverture.id }}, '{{ ouverture.nom }}')">
                                            <div class="card-body text-center">
                                                <div class="mb-3">
                                                    <i class="bi bi-door-open display-4 text-primary"></i>
                                                </div>
                                                <h5 class="card-title">{{ ouverture.nom }}</h5>
                                                <input type="radio" 
                                                       name="ouverture_id" 
                                                       value="{{ ouverture.id }}" 
                                                       id="ouverture_{{ ouverture.id }}" 
                                                       class="form-check-input d-none ouverture-radio">
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="row mt-4">
                                <div class="col-12">
                                    <div class="d-flex justify-content-between">
                                        <a href="{{ path('app_configuration_pf_subcategory', {projet: projet.id, confpf: confpf.id}) }}" 
                                           class="btn btn-outline-secondary">
                                            <i class="bi bi-arrow-left me-1"></i>Retour aux sous-catégories
                                        </a>
                                        
                                        <div>
                                            <a href="{{ path('app_configuration_pf_details', {projet: projet.id, confpf: confpf.id}) }}" 
                                               class="btn btn-outline-primary me-2">
                                                Passer cette étape
                                            </a>
                                            <button type="submit" class="btn btn-primary" id="submit-btn" disabled>
                                                Continuer <i class="bi bi-arrow-right ms-1"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.ouverture-card {
    transition: all 0.3s ease;
    border: 2px solid transparent;
}

.ouverture-card:hover {
    border-color: #0d6efd;
    box-shadow: 0 4px 8px rgba(13, 110, 253, 0.2);
    transform: translateY(-2px);
}

.ouverture-card.selected {
    border-color: #0d6efd;
    background-color: rgba(13, 110, 253, 0.1);
}

.ouverture-card.selected .card-title {
    color: #0d6efd;
    font-weight: bold;
}
</style>

<script>
function selectOuverture(id, nom) {
    // Désélectionner toutes les cartes
    document.querySelectorAll('.ouverture-card').forEach(card => {
        card.classList.remove('selected');
    });
    
    // Décocher tous les radios
    document.querySelectorAll('.ouverture-radio').forEach(radio => {
        radio.checked = false;
    });
    
    // Sélectionner la carte cliquée
    event.currentTarget.classList.add('selected');
    
    // Cocher le radio correspondant
    document.getElementById('ouverture_' + id).checked = true;
    
    // Activer le bouton submit
    document.getElementById('submit-btn').disabled = false;
    
    // Mettre à jour le texte du bouton avec le nom de l'ouverture
    document.getElementById('submit-btn').innerHTML = 
        'Continuer avec ' + nom + ' <i class="bi bi-arrow-right ms-1"></i>';
}

// Désactiver le bouton submit au chargement
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('submit-btn').disabled = true;
});
</script>
{% endblock %}