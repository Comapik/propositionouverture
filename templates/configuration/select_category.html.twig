{% extends 'base.html.twig' %}

{% block title %}Configuration Portes/Fenêtres - Sélection de la catégorie{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        Sélection de la catégorie
                    </h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h5 class="text-muted">Projet : {{ projet.refClient }}</h5>
                        <p class="text-muted">{{ projet.description }}</p>
                    </div>

                    <div class="alert alert-success">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        Produit sélectionné : <strong>{{ produit.nom }}</strong>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Étape 2/3 : Choisissez maintenant la catégorie pour ce produit.
                    </div>

                    {% if categories|length > 0 %}
                        <form method="post">
                            <div class="row g-3">
                                {% for categorie in categories %}
                                    <div class="col-md-6">
                                        <div class="card border category-card" style="cursor: pointer;">
                                            <div class="card-body text-center p-4">
                                                <div class="mb-3">
                                                    <i class="bi bi-folder text-primary" style="font-size: 2.5rem;"></i>
                                                </div>
                                                <h6 class="card-title">{{ categorie.nom }}</h6>
                                                {% if categorie.sousCategories|length > 0 %}
                                                    <small class="text-muted">
                                                        {{ categorie.sousCategories|length }} sous-catégorie{{ categorie.sousCategories|length > 1 ? 's' : '' }}
                                                    </small>
                                                {% endif %}
                                                <input type="radio" name="categorie_id" value="{{ categorie.id }}" class="d-none category-radio">
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="d-flex justify-content-between mt-4">
                                <a href="{{ path('app_configuration_pf', {'projet': projet.id}) }}" 
                                   class="btn btn-secondary">
                                    <i class="bi bi-arrow-left me-2"></i>
                                    Changer de produit
                                </a>
                                
                                <button type="submit" class="btn btn-primary btn-lg" id="submit-btn" disabled>
                                    <i class="bi bi-arrow-right me-2"></i>
                                    Continuer
                                </button>
                            </div>
                        </form>
                    {% else %}
                        <div class="alert alert-warning text-center">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Aucune catégorie disponible pour ce produit.
                            <br>
                            <a href="{{ path('app_configuration_pf', {'projet': projet.id}) }}" 
                               class="btn btn-primary mt-3">
                                <i class="bi bi-arrow-left me-2"></i>
                                Choisir un autre produit
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Progress indicator -->
            <div class="card mt-3 border-0">
                <div class="card-body py-2">
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 66%"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <small class="text-success fw-bold">✓ Produit</small>
                        <small class="text-primary fw-bold">→ Catégorie</small>
                        <small class="text-muted">Sous-catégorie</small>
                        <small class="text-muted">Configuration</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.category-card {
    transition: all 0.3s ease;
    cursor: pointer;
}

.category-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    border-color: #0d6efd !important;
}

.category-card.selected {
    border-color: #0d6efd !important;
    background-color: rgba(13, 110, 253, 0.1);
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(13, 110, 253, 0.3);
}

.category-card.selected .card-title {
    color: #0d6efd;
    font-weight: bold;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const categoryCards = document.querySelectorAll('.category-card');
    const submitBtn = document.getElementById('submit-btn');
    const radioInputs = document.querySelectorAll('.category-radio');
    
    categoryCards.forEach((card, index) => {
        card.addEventListener('click', function() {
            // Remove selected class from all cards
            categoryCards.forEach(c => c.classList.remove('selected'));
            
            // Add selected class to clicked card
            card.classList.add('selected');
            
            // Check the corresponding radio button
            radioInputs[index].checked = true;
            
            // Enable submit button
            submitBtn.disabled = false;
            submitBtn.classList.remove('btn-secondary');
            submitBtn.classList.add('btn-primary');
        });
    });
    
    // Form validation
    const form = document.querySelector('form');
    if (form) {
        form.addEventListener('submit', function(event) {
            const selectedRadio = document.querySelector('.category-radio:checked');
            if (!selectedRadio) {
                event.preventDefault();
                alert('Veuillez sélectionner une catégorie.');
            }
        });
    }
});
</script>
{% endblock %}