{% extends 'base.html.twig' %}

{% block title %}Choix de l'aérateur - {{ projet.refClient }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <!-- En-tête avec breadcrumb -->
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <div class="row align-items-center">
                        <div class="col">
                            <h2 class="h4 mb-0">
                                <i class="fas fa-fan me-2"></i>
                                Choix de l'aérateur
                            </h2>
                            <small class="opacity-75">{{ projet.refClient }}{% if projet.description %} - {{ projet.description }}{% endif %} - Configuration {{ confpf.id }}</small>
                        </div>
                        <div class="col-auto">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb bg-transparent mb-0">
                                    <li class="breadcrumb-item">
                                        <a href="{{ path('app_projet_show', {'id': projet.id}) }}" class="text-white-50">
                                            <i class="fas fa-project-diagram"></i> Projet
                                        </a>
                                    </li>
                                    <li class="breadcrumb-item text-white-75">Produit</li>
                                    <li class="breadcrumb-item text-white-75">Catégorie</li>
                                    <li class="breadcrumb-item text-white-75">Sous-catégorie</li>
                                    <li class="breadcrumb-item text-white-75">Ouverture</li>
                                    <li class="breadcrumb-item text-white-75">Détails</li>
                                    <li class="breadcrumb-item text-white-75">Couleurs</li>
                                    <li class="breadcrumb-item text-white-75">Vitrage</li>
                                    <li class="breadcrumb-item active text-white">Aérateur</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Récapitulatif de la configuration actuelle -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow h-100">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        Récapitulatif de la configuration
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Produit :</strong>
                        <span class="badge bg-primary">{{ produit.nom }}</span>
                    </div>
                    <div class="mb-3">
                        <strong>Catégorie :</strong>
                        <span class="badge bg-secondary">{{ categorie.nom }}</span>
                    </div>
                    <div class="mb-3">
                        <strong>Sous-catégorie :</strong>
                        <span class="badge bg-info">{{ sousCategorie.nom }}</span>
                    </div>
                    {% if confpf.ouverture %}
                    <div class="mb-3">
                        <strong>Ouverture :</strong>
                        <span class="badge bg-success">{{ confpf.ouverture.nom }}</span>
                    </div>
                    {% endif %}
                    {% if confpf.couleurInterieur %}
                    <div class="mb-3">
                        <strong>Couleur intérieur :</strong>
                        <span class="badge" style="background-color: {{ confpf.couleurInterieur.codeHex ?? '#cccccc' }}; color: #000;">{{ confpf.couleurInterieur.nom }}</span>
                    </div>
                    {% endif %}
                    {% if confpf.couleurExterieur %}
                    <div class="mb-3">
                        <strong>Couleur extérieur :</strong>
                        <span class="badge" style="background-color: {{ confpf.couleurExterieur.codeHex ?? '#cccccc' }}; color: #000;">{{ confpf.couleurExterieur.nom }}</span>
                    </div>
                    {% endif %}
                    {% if confpf.vitrage %}
                    <div class="mb-3">
                        <strong>Vitrage :</strong>
                        <span class="badge bg-warning">{{ confpf.vitrage.type }}</span>
                    </div>
                    {% endif %}
                    {% if selectedPosition %}
                    <div class="mb-3">
                        <strong>Position aérateur :</strong>
                        <span class="badge bg-warning text-dark">{{ selectedPosition.position }}</span>
                    </div>
                    {% endif %}
                    <hr>
                    <div class="mt-3">
                        <a href="{{ path('app_configuration_pf_vitrage', {'projet': projet.id, 'confpf': confpf.id}) }}" class="btn btn-sm btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Retour au vitrage
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Formulaire de sélection de l'aérateur -->
        <div class="col-lg-8">
            <form method="POST" action="{{ path('app_configuration_pf_aeration', {'projet': projet.id, 'confpf': confpf.id}) }}" id="aerationForm">
                <!-- Section 1 : Choix de la position -->
                <div class="card shadow mb-4">
                    <div class="card-header bg-light">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-map-pin me-2"></i>
                            Étape 1 : Sélectionnez la position de l'aérateur
                        </h5>
                    </div>
                    <div class="card-body">
                        {% if positions %}
                            <ul class="list-unstyled">
                                {% for position_item in positions %}
                                    <li class="mb-3">
                                        <label class="form-check-label cursor-pointer d-flex align-items-center p-3 border rounded position-option" for="position_{{ position_item.id }}">
                                            <input class="form-check-input me-3" type="radio" name="position" value="{{ position_item.id }}" id="position_{{ position_item.id }}" {% if selectedPosition and selectedPosition.id == position_item.id %}checked{% endif %} onchange="loadAerationsForPosition({{ position_item.id }})">
                                            <div class="flex-grow-1">
                                                <strong>{{ position_item.position }}</strong>
                                            </div>
                                        </label>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Aucune position disponible pour cette configuration.
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Section 2 : Choix du modèle (affichée seulement si position sélectionnée) -->
                {% if selectedPosition and aerations %}
                    <div class="card shadow mb-4 aeration-section">
                        <div class="card-header bg-light">
                            <h5 class="card-title mb-0">
                                <i class="fas fa-fan me-2"></i>
                                Étape 2 : Sélectionnez un modèle d'aérateur
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-3">
                                <strong>Position sélectionnée :</strong> <span class="badge bg-warning text-dark">{{ selectedPosition.position }}</span>
                            </p>
                            <ul class="list-unstyled">
                                {% for aeration in aerations %}
                                    <li class="mb-3">
                                        <label class="form-check-label cursor-pointer d-flex align-items-center p-3 border rounded aeration-option" for="aeration_{{ aeration.id }}">
                                            <input class="form-check-input me-3" type="radio" name="aeration" value="{{ aeration.id }}" id="aeration_{{ aeration.id }}" {% if confpf.confAeration and confpf.confAeration.aeration.id == aeration.id and confpf.confAeration.position.id == selectedPosition.id %}checked{% endif %}>
                                            <div class="flex-grow-1">
                                                <strong>{{ aeration.modele }}</strong>
                                            </div>
                                        </label>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                {% elseif selectedPosition and not aerations %}
                    <div class="alert alert-info aeration-section">
                        <i class="fas fa-info-circle me-2"></i>
                        Aucun modèle disponible pour cette position.
                    </div>
                {% endif %}

                <!-- Boutons de navigation -->
                <div class="mt-4 d-flex justify-content-between">
                    <a href="{{ path('app_configuration_pf_vitrage', {'projet': projet.id, 'confpf': confpf.id}) }}" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Retour
                    </a>
                    <button type="submit" class="btn btn-primary" {% if not selectedPosition %}disabled{% endif %} id="submitBtn">
                        <i class="fas fa-check me-2"></i>Confirmer et continuer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .position-option {
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .position-option:hover {
        background-color: #f8f9fa;
        border-color: #0d6efd !important;
    }

    .position-option input[type="radio"]:checked {
        accent-color: #0d6efd;
    }

    .position-option:has(input[type="radio"]:checked) {
        background-color: #e7f1ff;
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }

    .aeration-option {
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .aeration-option:hover {
        background-color: #f8f9fa;
        border-color: #0d6efd !important;
    }

    .aeration-option input[type="radio"]:checked {
        accent-color: #0d6efd;
    }

    .aeration-option:has(input[type="radio"]:checked) {
        background-color: #e7f1ff;
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }

    .aeration-section {
        animation: slideIn 0.3s ease;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    function loadAerationsForPosition(positionId) {
        // Redirection avec la position en query string pour afficher les aérateurs
        window.location.href = '{{ path("app_configuration_pf_aeration", {"projet": projet.id, "confpf": confpf.id}) }}?position=' + positionId;
    }
</script>
{% endblock %}
