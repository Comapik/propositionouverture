{% extends 'base.html.twig' %}

{% block title %}Gestion des Types Fenêtre/Porte - {{ parent() }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="bi bi-tools"></i>
                        Gestion temporaire des Types de Fenêtre/Porte
                    </h4>
                    <small class="text-muted">⚠️ Page de développement - À supprimer en production</small>
                </div>
                <div class="card-body">
                    
                    <!-- Actions rapides -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h6 class="mb-0">Actions rapides</h6>
                                </div>
                                <div class="card-body">
                                    <form method="post" action="{{ path('app_temp_type_fenetre_porte_bulk_create') }}">
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-plus-circle"></i>
                                            Créer les types par défaut
                                        </button>
                                    </form>
                                    <small class="text-muted mt-2 d-block">
                                        Crée automatiquement 12 types de fenêtre/porte standards
                                    </small>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="card border-info">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Navigation</h6>
                                </div>
                                <div class="card-body">
                                    <a href="{{ path('app_admin_compatibilites_index') }}" class="btn btn-primary btn-sm mb-2">
                                        <i class="bi bi-link-45deg"></i>
                                        Gérer les compatibilités
                                    </a>
                                    <br>
                                    <small class="text-muted">
                                        Interface complète pour gérer les relations entre types, ouvertures et systèmes
                                    </small>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="card border-success">
                                <div class="card-header bg-success text-white">
                                    <h6 class="mb-0">Statistiques</h6>
                                </div>
                                <div class="card-body">
                                    <p class="mb-1">
                                        <strong>Types créés :</strong> {{ types|length }}
                                    </p>
                                    <p class="mb-1">
                                        <strong>Systèmes disponibles :</strong> {{ systemes|length }}
                                    </p>
                                    <p class="mb-1">
                                        <strong>Ouvertures disponibles :</strong> {{ ouvertures|length }}
                                    </p>
                                    <p class="mb-0">
                                        <strong>Compatibilités totales :</strong> 
                                        {% set totalCompatibilites = 0 %}
                                        {% for type in types %}
                                            {% set totalCompatibilites = totalCompatibilites + compatibilites[type.id]|length %}
                                        {% endfor %}
                                        {{ totalCompatibilites }}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Formulaire de création -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="bi bi-plus"></i>
                                Créer un nouveau type
                            </h5>
                        </div>
                        <div class="card-body">
                            <form method="post" action="{{ path('app_temp_type_fenetre_porte_create') }}">
                                <div class="row">
                                    <div class="col-md-3 mb-3">
                                        <label for="nom" class="form-label">Nom du type <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="nom" name="nom" 
                                               placeholder="Ex: Fenêtre coulissante" required>
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label class="form-label">Ouvertures associées</label>
                                        <div class="row">
                                            {% for ouverture in ouvertures %}
                                                <div class="col-12 mb-1">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" 
                                                               name="ouvertures[]" value="{{ ouverture.id }}" 
                                                               id="ouverture_{{ ouverture.id }}">
                                                        <label class="form-check-label" for="ouverture_{{ ouverture.id }}">
                                                            {{ ouverture.nom }}
                                                        </label>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">Systèmes associés (optionnel)</label>
                                        <div class="row">
                                            {% for systeme in systemes %}
                                                <div class="col-md-6">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" 
                                                               name="systemes[]" value="{{ systeme.id }}" 
                                                               id="systeme_{{ systeme.id }}">
                                                        <label class="form-check-label" for="systeme_{{ systeme.id }}">
                                                            {{ systeme.nom }}
                                                            <small class="text-muted">({{ systeme.fournisseur.marque }})</small>
                                                        </label>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div class="col-md-2 d-flex align-items-end mb-3">
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="bi bi-plus"></i>
                                            Créer
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Liste des types existants -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="bi bi-list"></i>
                                Types de fenêtre/porte existants
                            </h5>
                        </div>
                        <div class="card-body">
                            {% if types|length > 0 %}
                                <div class="table-responsive">
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Nom</th>
                                                <th>Ouvertures compatibles</th>
                                                <th>Systèmes compatibles</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for type in types %}
                                                <tr>
                                                    <td>{{ type.id }}</td>
                                                    <td>
                                                        <strong>{{ type.nom }}</strong>
                                                    </td>
                                                    <td>
                                                        {% if compatibilites[type.id]|length > 0 %}
                                                            {% set ouverturesListe = [] %}
                                                            {% for compatibilite in compatibilites[type.id] %}
                                                                {% if compatibilite.ouverture.nom not in ouverturesListe %}
                                                                    {% set ouverturesListe = ouverturesListe|merge([compatibilite.ouverture.nom]) %}
                                                                {% endif %}
                                                            {% endfor %}
                                                            {% for ouverture in ouverturesListe %}
                                                                <span class="badge bg-success me-1">
                                                                    {{ ouverture }}
                                                                </span>
                                                            {% endfor %}
                                                        {% else %}
                                                            <span class="text-muted">Aucune compatibilité définie</span>
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        {% if compatibilites[type.id]|length > 0 %}
                                                            {% set systemesListe = {} %}
                                                            {% for compatibilite in compatibilites[type.id] %}
                                                                {% if compatibilite.systeme.id not in systemesListe|keys %}
                                                                    {% set systemesListe = systemesListe|merge({(compatibilite.systeme.id): compatibilite.systeme}) %}
                                                                {% endif %}
                                                            {% endfor %}
                                                            {% for systeme in systemesListe %}
                                                                <span class="badge bg-info me-1">
                                                                    {{ systeme.nom }}
                                                                    <small>({{ systeme.fournisseur.marque }})</small>
                                                                </span>
                                                            {% endfor %}
                                                            <br>
                                                            <small class="text-muted">{{ compatibilites[type.id]|length }} compatibilité(s)</small>
                                                        {% else %}
                                                            <span class="text-muted">Aucune compatibilité définie</span>
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        <!-- Bouton pour modifier les relations -->
                                                        <button type="button" class="btn btn-sm btn-outline-primary" 
                                                                data-bs-toggle="modal" 
                                                                data-bs-target="#associateModal{{ type.id }}">
                                                            <i class="bi bi-link-45deg"></i>
                                                            Relations
                                                        </button>
                                                        
                                                        <!-- Bouton de suppression -->
                                                        <form method="post" 
                                                              action="{{ path('app_temp_type_fenetre_porte_delete', {id: type.id}) }}" 
                                                              class="d-inline" 
                                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce type ?')">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                <i class="bi bi-trash"></i>
                                                                Supprimer
                                                            </button>
                                                        </form>

                                                        {# Formulaire pour ajouter une ouverture compatible en conservant les systèmes existants #}
                                                        {% set ouvertureIdsExistantes = [] %}
                                                        {% for compatibilite in compatibilites[type.id] %}
                                                            {% set ouvertureIdsExistantes = ouvertureIdsExistantes|merge([compatibilite.ouverture.id]) %}
                                                        {% endfor %}

                                                        {% set ouverturesCandidates = [] %}
                                                        {% for ouverture in ouvertures %}
                                                            {% if ouverture.id not in ouvertureIdsExistantes %}
                                                                {% set ouverturesCandidates = ouverturesCandidates|merge([ouverture]) %}
                                                            {% endif %}
                                                        {% endfor %}
                                                        <form method="post" 
                                                              action="{{ path('app_temp_type_fenetre_porte_add_ouverture', {id: type.id}) }}" 
                                                              class="mt-2">
                                                            {% if ouverturesCandidates|length > 0 %}
                                                                <select name="ouverture_ids[]" class="form-select form-select-sm mb-2" multiple size="6" required>
                                                                    {% for ouverture in ouverturesCandidates %}
                                                                        <option value="{{ ouverture.id }}">{{ ouverture.nom }}</option>
                                                                    {% endfor %}
                                                                </select>
                                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                                    <i class="bi bi-plus-circle"></i>
                                                                    Ajouter sélection
                                                                </button>
                                                                <small class="text-muted d-block mt-1">Associé à tous les systèmes déjà compatibles. Cmd/Ctrl+clic pour multi-sélection.</small>
                                                            {% else %}
                                                                <small class="text-muted d-block">Toutes les ouvertures sont déjà associées.</small>
                                                            {% endif %}
                                                        </form>

                                                        {# Formulaire pour ajouter un système compatible en conservant les ouvertures existantes #}
                                                        {% set systemeIdsExistants = [] %}
                                                        {% for compatibilite in compatibilites[type.id] %}
                                                            {% if compatibilite.systeme %}
                                                                {% set systemeIdsExistants = systemeIdsExistants|merge([compatibilite.systeme.id]) %}
                                                            {% endif %}
                                                        {% endfor %}

                                                        {% set systemesCandidates = [] %}
                                                        {% for systeme in systemes %}
                                                            {% if systeme.id not in systemeIdsExistants %}
                                                                {% set systemesCandidates = systemesCandidates|merge([systeme]) %}
                                                            {% endif %}
                                                        {% endfor %}
                                                        <form method="post"
                                                              action="{{ path('app_temp_type_fenetre_porte_add_systeme', {id: type.id}) }}"
                                                              class="mt-2">
                                                            {% if systemesCandidates|length > 0 %}
                                                                <select name="systeme_ids[]" class="form-select form-select-sm mb-2" multiple size="6" required>
                                                                    {% for systeme in systemesCandidates %}
                                                                        <option value="{{ systeme.id }}">{{ systeme.nom }} ({{ systeme.fournisseur.marque }})</option>
                                                                    {% endfor %}
                                                                </select>
                                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                                    <i class="bi bi-plus-circle"></i>
                                                                    Ajouter sélection
                                                                </button>
                                                                <small class="text-muted d-block mt-1">Associé à toutes les ouvertures déjà compatibles. Cmd/Ctrl+clic pour multi-sélection.</small>
                                                            {% else %}
                                                                <small class="text-muted d-block">Tous les systèmes sont déjà associés.</small>
                                                            {% endif %}
                                                        </form>
                                                    </td>
                                                </tr>

                                                <!-- Modal pour modifier les associations -->
                                                <div class="modal fade" id="associateModal{{ type.id }}" tabindex="-1">
                                                    <div class="modal-dialog modal-xl modal-dialog-scrollable">
                                                        <div class="modal-content">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">
                                                                    Gérer les compatibilités : "{{ type.nom }}"
                                                                </h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <form method="post" action="{{ path('app_temp_type_fenetre_porte_associate', {id: type.id}) }}">
                                                                <div class="modal-body">
                                                                    <div class="alert alert-info">
                                                                        <i class="bi bi-info-circle"></i>
                                                                        <strong>Important :</strong> Sélectionnez les ouvertures ET les systèmes pour créer les compatibilités. 
                                                                        Chaque combinaison ouverture/système sélectionnée créera une compatibilité.
                                                                    </div>
                                                                    
                                                                    <!-- Section Ouvertures -->
                                                                    <h6 class="mt-3 mb-2">Ouvertures compatibles</h6>
                                                                    <div class="row mb-4">
                                                                        {% for ouverture in ouvertures %}
                                                                            <div class="col-md-6 mb-2">
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" 
                                                                                           name="ouvertures[]" value="{{ ouverture.id }}" 
                                                                                           id="modal_ouverture_{{ type.id }}_{{ ouverture.id }}">
                                                                                    <label class="form-check-label" for="modal_ouverture_{{ type.id }}_{{ ouverture.id }}">
                                                                                        {{ ouverture.nom }}
                                                                                    </label>
                                                                                </div>
                                                                            </div>
                                                                        {% endfor %}
                                                                    </div>
                                                                    
                                                                    <!-- Section Systèmes -->
                                                                    <h6 class="mt-3 mb-2">Systèmes compatibles</h6>
                                                                    <div class="row">
                                                                        {% for systeme in systemes %}
                                                                            <div class="col-md-12 mb-2">
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" 
                                                                                           name="systemes[]" value="{{ systeme.id }}" 
                                                                                           id="modal_systeme_{{ type.id }}_{{ systeme.id }}">
                                                                                    <label class="form-check-label" for="modal_systeme_{{ type.id }}_{{ systeme.id }}">
                                                                                        <strong>{{ systeme.nom }}</strong>
                                                                                        <br>
                                                                                        <small class="text-muted">{{ systeme.fournisseur.marque }}</small>
                                                                                        {% if systeme.urlImage %}
                                                                                            <br>
                                                                                            <small class="text-muted">Image disponible</small>
                                                                                        {% endif %}
                                                                                    </label>
                                                                                </div>
                                                                            </div>
                                                                        {% endfor %}
                                                                    </div>
                                                                </div>
                                                                <div class="modal-footer">
                                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                                        Annuler
                                                                    </button>
                                                                    <button type="submit" class="btn btn-primary">
                                                                        <i class="bi bi-check"></i>
                                                                        Sauvegarder
                                                                    </button>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="alert alert-info text-center">
                                    <i class="bi bi-info-circle"></i>
                                    Aucun type de fenêtre/porte créé pour le moment.
                                    <br>
                                    Utilisez le bouton "Créer les types par défaut" pour commencer.
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Retour au menu principal -->
                    <div class="mt-4 text-center">
                        <a href="{{ path('app_home') }}" class="btn btn-secondary">
                            <i class="bi bi-house"></i>
                            Retour au menu principal
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.card {
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
}

.badge {
    font-size: 0.8em;
}

.form-check-label small {
    color: #6c757d;
}

.modal-body {
    max-height: 70vh;
    overflow-y: auto;
}

/* Rendre la colonne Actions plus large pour accueillir les formulaires */
.table th:last-child,
.table td:last-child {
    min-width: 520px;
}
</style>
{% endblock %}