{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<div class="container mt-5">
    

    <!-- Section des projets -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-folder2-open"></i>
                        Liste des Projets
                        <span class="badge bg-primary ms-2">{{ totalProjets }}</span>
                    </h4>
                    <a href="{{ path('app_projet_new') }}" class="btn btn-success btn-sm">
                        <i class="bi bi-plus-circle"></i> Nouveau Projet
                    </a>
                </div>
                <div class="card-body">
                    {% if projets|length > 0 %}
                        {# Vue tableau pour desktop #}
                        <div class="table-responsive d-none d-lg-block">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Référence Client</th>
                                        <th scope="col">Client</th>
                                        <th scope="col">Description</th>
                                        <th scope="col">Lieu</th>
                                        <th scope="col">Date de création</th>
                                        <th scope="col">Configuration</th>
                                        <th scope="col">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for projet in projets %}
                                    <tr>
                                        <td>{{ projet.id }}</td>
                                        <td>
                                            <strong>{{ projet.refClient }}</strong>
                                        </td>
                                        <td>
                                            {% if projet.client %}
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 14px;">
                                                        {{ projet.client.nom|first|upper }}
                                                    </div>
                                                    <div>
                                                        <strong>{{ projet.client.nom }}</strong>
                                                        {% if projet.client.email %}
                                                            <br><small class="text-muted">{{ projet.client.email }}</small>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            {% else %}
                                                <span class="text-muted">Aucun client</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if projet.description %}
                                                {{ projet.description|u.truncate(50, '...') }}
                                            {% else %}
                                                <span class="text-muted">Aucune description</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if projet.lieu %}
                                                <i class="bi bi-geo-alt-fill text-muted"></i>
                                                {{ projet.lieu }}
                                            {% else %}
                                                <span class="text-muted">Non spécifié</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                {{ projet.createdAt|date('d/m/Y H:i') }}
                                            </small>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                {% if projet.confPfId %}
                                                    <span class="badge bg-success" title="Portes/Fenêtres configurées">
                                                        <i class="bi bi-window"></i>
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-light text-dark" title="Portes/Fenêtres non configurées">
                                                        <i class="bi bi-window"></i>
                                                    </span>
                                                {% endif %}
                                                
                                                {% if projet.confVoletId %}
                                                    <span class="badge bg-info" title="Volets configurés">
                                                        <i class="bi bi-house-door"></i>
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-light text-dark" title="Volets non configurés">
                                                        <i class="bi bi-house-door"></i>
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('app_projet_show', {id: projet.id}) }}" class="btn btn-outline-info" title="Voir">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <form method="post" action="{{ path('app_projet_duplicate', {id: projet.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ projet.id) }}">
                                                    <button class="btn btn-outline-secondary" type="submit" title="Dupliquer">
                                                        <i class="bi bi-copy"></i>
                                                    </button>
                                                </form>
                                                <a href="{{ path('app_projet_edit', {id: projet.id}) }}" class="btn btn-outline-warning" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form method="post" action="{{ path('app_projet_delete', {id: projet.id}) }}" class="d-inline" onsubmit="return confirmDelete('{{ projet.refClient|e('js') }}')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.id) }}">
                                                    <button class="btn btn-outline-danger" type="submit" title="Supprimer">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        {# Vue cartes pour tablette et mobile #}
                        <div class="d-lg-none">
                            {% for projet in projets %}
                            <div class="card mb-3 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title mb-0">
                                            <i class="bi bi-folder2-open text-primary"></i>
                                            {{ projet.refClient }}
                                        </h5>
                                        <span class="badge bg-secondary">#{{ projet.id }}</span>
                                    </div>

                                    {% if projet.client %}
                                    <div class="mb-3">
                                        <small class="text-muted d-block"><i class="bi bi-person-fill"></i> Client</small>
                                        <div class="d-flex align-items-center mt-1">
                                            <div class="avatar bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 14px;">
                                                {{ projet.client.nom|first|upper }}
                                            </div>
                                            <div>
                                                <strong>{{ projet.client.nom }}</strong>
                                                {% if projet.client.email %}
                                                    <br><small class="text-muted">{{ projet.client.email }}</small>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                    {% endif %}

                                    {% if projet.description %}
                                    <div class="mb-2">
                                        <small class="text-muted"><i class="bi bi-file-text"></i> Description</small>
                                        <p class="mb-0">{{ projet.description }}</p>
                                    </div>
                                    {% endif %}

                                    {% if projet.lieu %}
                                    <div class="mb-2">
                                        <small class="text-muted"><i class="bi bi-geo-alt-fill"></i> Lieu</small>
                                        <p class="mb-0">{{ projet.lieu }}</p>
                                    </div>
                                    {% endif %}

                                    <div class="mb-3">
                                        <small class="text-muted"><i class="bi bi-calendar3"></i> Date de création</small>
                                        <p class="mb-0">{{ projet.createdAt|date('d/m/Y à H:i') }}</p>
                                    </div>

                                    <div class="mb-3">
                                        <small class="text-muted d-block mb-2"><i class="bi bi-gear-fill"></i> Configuration</small>
                                        <div class="d-flex gap-2">
                                            {% if projet.confPfId %}
                                                <span class="badge bg-success">
                                                    <i class="bi bi-window"></i> Portes/Fenêtres
                                                </span>
                                            {% else %}
                                                <span class="badge bg-light text-dark">
                                                    <i class="bi bi-window"></i> Portes/Fenêtres
                                                </span>
                                            {% endif %}
                                            
                                            {% if projet.confVoletId %}
                                                <span class="badge bg-info">
                                                    <i class="bi bi-house-door"></i> Volets
                                                </span>
                                            {% else %}
                                                <span class="badge bg-light text-dark">
                                                    <i class="bi bi-house-door"></i> Volets
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2 justify-content-start">
                                        <a href="{{ path('app_projet_show', {id: projet.id}) }}" class="btn btn-info btn-sm">
                                            <i class="bi bi-eye"></i> Voir
                                        </a>
                                        <form method="post" action="{{ path('app_projet_duplicate', {id: projet.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ projet.id) }}">
                                            <button class="btn btn-secondary btn-sm" type="submit">
                                                <i class="bi bi-copy"></i> Dupliquer
                                            </button>
                                        </form>
                                        <a href="{{ path('app_projet_edit', {id: projet.id}) }}" class="btn btn-warning btn-sm">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                        <form method="post" action="{{ path('app_projet_delete', {id: projet.id}) }}" class="d-inline" onsubmit="return confirmDelete('{{ projet.refClient|e('js') }}')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.id) }}">
                                            <button class="btn btn-danger btn-sm" type="submit">
                                                <i class="bi bi-trash"></i> Supprimer
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <i class="bi bi-folder2-open text-muted" style="font-size: 3rem;"></i>
                            </div>
                            <h5 class="text-muted">Aucun projet trouvé</h5>
                            <p class="text-muted">Commencez par créer votre premier projet.</p>
                            <a href="{{ path('app_projet_new') }}" class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Créer un projet
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function confirmDelete(refClient) {
    return confirm('Êtes-vous sûr de vouloir supprimer le projet "' + refClient + '" ?\n\nCette action est irréversible et supprimera également :\n- Toutes les configurations associées\n- Tous les PDFs générés\n- Toutes les photos du projet');
}
</script>
{% endblock %}