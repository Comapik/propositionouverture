{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<div class="container mt-5">
    

    <!-- Section des projets -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-folder2-open"></i>
                        Liste des Projets
                        <span class="badge bg-primary ms-2">{{ totalProjets }}</span>
                    </h4>
                    <a href="{{ path('app_projet_new') }}" class="btn btn-success btn-sm">
                        <i class="bi bi-plus-circle"></i> Nouveau Projet
                    </a>
                </div>
                <div class="card-body">
                    {% if projets|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Référence Client</th>
                                        <th scope="col">Client</th>
                                        <th scope="col">Description</th>
                                        <th scope="col">Lieu</th>
                                        <th scope="col">Date de création</th>
                                        <th scope="col">Configuration</th>
                                        <th scope="col">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for projet in projets %}
                                    <tr>
                                        <td>{{ projet.id }}</td>
                                        <td>
                                            <strong>{{ projet.refClient }}</strong>
                                        </td>
                                        <td>
                                            {% if projet.client %}
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 14px;">
                                                        {{ projet.client.nom|first|upper }}
                                                    </div>
                                                    <div>
                                                        <strong>{{ projet.client.nom }}</strong>
                                                        {% if projet.client.email %}
                                                            <br><small class="text-muted">{{ projet.client.email }}</small>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            {% else %}
                                                <span class="text-muted">Aucun client</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if projet.description %}
                                                {{ projet.description|u.truncate(50, '...') }}
                                            {% else %}
                                                <span class="text-muted">Aucune description</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if projet.lieu %}
                                                <i class="bi bi-geo-alt-fill text-muted"></i>
                                                {{ projet.lieu }}
                                            {% else %}
                                                <span class="text-muted">Non spécifié</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                {{ projet.createdAt|date('d/m/Y H:i') }}
                                            </small>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                {% if projet.confPfId %}
                                                    <span class="badge bg-success" title="Portes/Fenêtres configurées">
                                                        <i class="bi bi-window"></i>
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-light text-dark" title="Portes/Fenêtres non configurées">
                                                        <i class="bi bi-window"></i>
                                                    </span>
                                                {% endif %}
                                                
                                                {% if projet.confVoletId %}
                                                    <span class="badge bg-info" title="Volets configurés">
                                                        <i class="bi bi-house-door"></i>
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-light text-dark" title="Volets non configurés">
                                                        <i class="bi bi-house-door"></i>
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('app_projet_show', {id: projet.id}) }}" class="btn btn-outline-info" title="Voir">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a href="{{ path('app_projet_edit', {id: projet.id}) }}" class="btn btn-outline-warning" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <i class="bi bi-folder2-open text-muted" style="font-size: 3rem;"></i>
                            </div>
                            <h5 class="text-muted">Aucun projet trouvé</h5>
                            <p class="text-muted">Commencez par créer votre premier projet.</p>
                            <a href="{{ path('app_projet_new') }}" class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Créer un projet
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}